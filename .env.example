# Email delivery for leads via Resend API.
# Add the same variables in Vercel: Project Settings -> Environment Variables.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=Screed Master <leads@your-domain.com>
RESEND_TO=lead-recipient@example.com

# Legacy SMTP delivery. Used only if RESEND_API_KEY is not set.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FAMILY=4
SMTP_USER=your-mail@example.com
SMTP_PASS=your-app-password
SMTP_FROM=your-mail@example.com
SMTP_TO=lead-recipient@example.com

# Optional channels. Leave empty or do not set if you only want email.
TG_BOT_TOKEN=your-telegram-bot-token
TG_CHAT_IDS=711139656,business-owner-chat-id
# Legacy single-recipient fallback. Prefer TG_CHAT_IDS for you + business owner.
TG_CHAT_ID=
VK_GROUP_TOKEN=
VK_OWNER_USER_ID=
VK_MASTER_USER_ID=

# Optional for static hosting such as GitHub Pages.
# Point this to a deployed backend that serves POST /api/lead.
VITE_LEAD_ENDPOINT=
